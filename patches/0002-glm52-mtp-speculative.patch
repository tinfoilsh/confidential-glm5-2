+        # (PR #45895: Indexer init skip and MTP TopK share for iteration)
+        if use_sparse:
+            extra_impl_args["topk_indices_buffer"] = topk_indices_buffer
+
         if (
             cache_config is not None
             and cache_config.enable_prefix_caching

